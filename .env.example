# ─────────────────────────────────────────────────────────────────────────────
# Overclock — Environment Variables
#
# Copy this file to .env and fill in your Supabase project values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE CONNECTION ─────────────────────────────────────────────────────
# Your Supabase project URL (found in Project Settings → API)
# Supports both NEXT_PUBLIC_ (Vercel/Next.js) and VITE_ (local dev) prefixes
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Your Supabase anonymous/public key (found in Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── NOTES ───────────────────────────────────────────────────────────────────
# The database layer automatically detects which environment variables are
# available and uses the appropriate ones:
#
#   Priority: NEXT_PUBLIC_* > VITE_*
#
# You only need to set ONE of each pair (NEXT_PUBLIC_* OR VITE_*), but you
# can set both for environments that need both.
#
# For Vercel deployments, use the Supabase integration which automatically
# provisions the NEXT_PUBLIC_* variables.

# ── AD NETWORKS (Mobile & Web Monetization) ─────────────────────────────────
# Google AdMob - Real rewarded ads for mobile (iOS/Android via Capacitor)
# Get these from your AdMob account
VITE_ADMOB_APP_ID=ca-app-pub-9196447836572769~2813228142
VITE_ADMOB_REWARDED_UNIT_ID=ca-app-pub-9196447836572769/7939916372
VITE_ADMOB_IOS_REWARDED_UNIT_ID=ca-app-pub-9196447836572769/7939916372
VITE_ADMOB_ANDROID_REWARDED_UNIT_ID=ca-app-pub-9196447836572769/7939916372

# Google AdSense - Display ads for web monetization
# Get these from your AdSense account (optional - only needed for web ads)
# VITE_ADSENSE_PUBLISHER_ID=ca-pub-9196447836572769
# VITE_ADSENSE_AD_SLOT_ID=1234567890123456
