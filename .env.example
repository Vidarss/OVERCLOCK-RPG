# ─────────────────────────────────────────────────────────────────────────────
# Overclock — Environment Variables
#
# Copy this file to .env and fill in your Supabase project values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE CONNECTION ─────────────────────────────────────────────────────
# Your Supabase project URL (found in Project Settings → API)
# Supports both NEXT_PUBLIC_ (Vercel/Next.js) and VITE_ (local dev) prefixes
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Your Supabase anonymous/public key (found in Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── NOTES ───────────────────────────────────────────────────────────────────
# The database layer automatically detects which environment variables are
# available and uses the appropriate ones:
#
#   Priority: NEXT_PUBLIC_* > VITE_*
#
# You only need to set ONE of each pair (NEXT_PUBLIC_* OR VITE_*), but you
# can set both for environments that need both.
#
# For Vercel deployments, use the Supabase integration which automatically
# provisions the NEXT_PUBLIC_* variables.
