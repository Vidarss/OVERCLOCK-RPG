# ─────────────────────────────────────────────────────────────────────────────
# OVERCLOCK.EXE — Environment Variables
#
# 1. Copy this file to .env
# 2. Fill in your values
# 3. Never commit .env to source control
# ─────────────────────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════════════════════
# SUPABASE (Required)
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
# ══════════════════════════════════════════════════════════════════════════════

# Project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anonymous/Public Key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (server-side only - NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ══════════════════════════════════════════════════════════════════════════════
# STRIPE - Web Payments (Required for Battle Pass purchases)
# Get these from: https://dashboard.stripe.com/apikeys
# ══════════════════════════════════════════════════════════════════════════════

# Secret Key (server-side only - NEVER expose to client)
STRIPE_SECRET_KEY=sk_test_...

# Publishable Key (safe to expose in frontend)
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook Secret (for webhook signature verification)
# Get from: https://dashboard.stripe.com/webhooks → Your Webhook → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ══════════════════════════════════════════════════════════════════════════════
# GOOGLE PLAY - Android In-App Purchases (Required for mobile monetization)
# Set up at: https://play.google.com/console → Your App → Monetize
# ══════════════════════════════════════════════════════════════════════════════

# Service Account JSON for Google Play Developer API (base64 encoded)
# Create at: https://console.cloud.google.com → IAM → Service Accounts
# Grant "Android Publisher" role, then download JSON key
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Your app's package name
GOOGLE_PLAY_PACKAGE_NAME=com.overclock.exe

# In-App Product IDs (configured in Google Play Console)
GOOGLE_PLAY_BATTLE_PASS_PRODUCT_ID=battle_pass_season_1

# ══════════════════════════════════════════════════════════════════════════════
# ADMOB - Mobile Ads (Required for APK monetization)
# Get these from: https://admob.google.com → Apps → Ad Units
# ══════════════════════════════════════════════════════════════════════════════

# Your AdMob App ID (found in App Settings)
VITE_ADMOB_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX

# Rewarded Ad Unit IDs (create separate units for each platform)
VITE_ADMOB_ANDROID_REWARDED_UNIT_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
VITE_ADMOB_IOS_REWARDED_UNIT_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# ══════════════════════════════════════════════════════════════════════════════
# APPLE APP STORE - iOS In-App Purchases (Future - for iOS launch)
# Set up at: https://appstoreconnect.apple.com → Your App → In-App Purchases
# ══════════════════════════════════════════════════════════════════════════════

# App Store Connect API Key (for receipt validation)
# APPLE_APP_STORE_SHARED_SECRET=...

# ══════════════════════════════════════════════════════════════════════════════
# CAPACITOR / ANDROID BUILD INFO
# (Configured in capacitor.config.ts - no env vars needed)
# ══════════════════════════════════════════════════════════════════════════════
# App ID: com.overclock.exe
# App Name: OVERCLOCK.EXE
# Web Dir: dist

# ══════════════════════════════════════════════════════════════════════════════
# BUILD COMMANDS QUICK REFERENCE
# ══════════════════════════════════════════════════════════════════════════════
#
# FIRST TIME SETUP:
#   1. pnpm install
#   2. pnpm build
#   3. pnpm cap:add:android
#
# BUILD APK:
#   1. pnpm build:android
#   2. In Android Studio: Build → Build Bundle(s) / APK(s) → Build APK(s)
#   3. APK location: android/app/build/outputs/apk/debug/app-debug.apk
#
# AFTER CODE CHANGES:
#   pnpm build:mobile
#
# REQUIREMENTS:
#   - Android Studio installed
#   - Android SDK installed
#   - Java JDK 17+
#
# ══════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT CHECKLIST
# ══════════════════════════════════════════════════════════════════════════════
#
# WEB (Vercel):
#   1. Connect GitHub repo to Vercel
#   2. Add all SUPABASE_*, STRIPE_* env vars in Vercel dashboard
#   3. Set up Stripe webhook pointing to: https://yourdomain.vercel.app/api/stripe/webhook
#   4. Deploy!
#
# ANDROID (Google Play):
#   1. Set up In-App Products in Google Play Console
#   2. Create service account for Google Play Developer API
#   3. Configure GOOGLE_PLAY_* env vars
#   4. Build signed APK/AAB
#   5. Upload to Google Play Console
#
# DATABASE:
#   1. Run migration: supabase db push
#   2. Or manually execute: supabase/migrations/20240601_purchases_and_battle_pass.sql
#
# ══════════════════════════════════════════════════════════════════════════════
